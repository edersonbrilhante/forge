{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^ansible/group_vars/all/common\\.yml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: registryUrl=(?<registryUrl>\\S+))?.*\\n[a-zA-Z0-9_]+: (?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["ansible-galaxy", "custom.regex", "github-actions", "packer"],
      "automerge": false
    }
  ]
}
