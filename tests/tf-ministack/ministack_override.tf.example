# ministack_override.tf
#
# O nome PRECISA terminar em _override.tf. O Terraform/OpenTofu MESCLA este
# arquivo no seu `provider "aws"` existente, adicionando os endpoints do
# MiniStack e as flags de skip SEM gerar erro de provider duplicado.
#
# Copie este arquivo para o diretorio do stack/modulo que voce quer testar
# (ou gere-o via Terragrunt - veja terragrunt-ministack.hcl).
provider "aws" {
  access_key                  = "test"
  secret_key                  = "test"
  region                      = "us-east-1"
  skip_credentials_validation = true
  skip_metadata_api_check     = true
  skip_requesting_account_id  = true
  s3_use_path_style           = true # essencial para S3 em emulador

  endpoints {
    s3          = "http://localhost:4566"
    sqs         = "http://localhost:4566"
    sns         = "http://localhost:4566"
    ssm         = "http://localhost:4566"
    iam         = "http://localhost:4566"
    sts         = "http://localhost:4566"
    lambda      = "http://localhost:4566"
    events      = "http://localhost:4566"
    logs        = "http://localhost:4566"
    cloudwatch  = "http://localhost:4566"
    kms         = "http://localhost:4566"
    ec2         = "http://localhost:4566"
    autoscaling = "http://localhost:4566"
    dynamodb    = "http://localhost:4566"
    eks         = "http://localhost:4566" # apenas control-plane (CRUD raso)
  }
}
